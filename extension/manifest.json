{
  "manifest_version": 3,
  "name": "Focus Tracker",
  "version": "1.0.0",
  "description": "Track your digital focus. Understand your productive vs distracting time. Privacy-first — all data stays on your device.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "activeTab",
    "idle"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["http://localhost:3000/*", "http://localhost:12278/*", "http://localhost/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Focus Tracker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
